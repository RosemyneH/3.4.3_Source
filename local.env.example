# Copy to local.env and adjust for your machine:
#   cp local.env.example local.env

# Build
BUILD_DIR=build
BUILD_TYPE=RelWithDebInfo
# Boost.Process headers (Arch Boost 1.91 omits them; fetched to local/.cache)
BOOST_PROCESS_REF=boost-1.86.0

# MariaDB (Arch: pacman install mariadb; service is mariadb.service)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_CLIENT=mariadb
MYSQL_SOCKET=/run/mysqld/mysqld.sock
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASS=
MYSQL_USER=trinity
MYSQL_PASS=trinity

# TrinityCore sql/ fetch (for sql/base and incremental updates)
TC_SQL_REF=master
TC_SQL_REPO=https://github.com/TrinityCore/TrinityCore.git

# TDB release files (must match revision_data.h.in.cmake)
TDB_WORLD_FILE=TDB_full_world_343.23121_2023_12_20.sql
TDB_HOTFIXES_FILE=TDB_full_hotfixes_343.23121_2023_12_20.sql
TDB_RELEASE_URL=https://github.com/TrinityCore/TrinityCore/releases/latest/download

# WoW client (CASC Data/) — leave empty to skip extraction
WOW_CLIENT_PATH=

# Realm (seeded into auth.realmlist on setup-database)
REALM_NAME=Trinity
REALM_PORT=8085
REALM_GAMEBUILD=54261
